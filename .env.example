# Локально: Docker postgres.
#
# Supabase на Vercel: для runtime приложения используйте Transaction pooler (порт 6543),
# НЕ Session pooler — у session mode жёсткий лимит соединений и ошибка MaxClientsInSessionMode.
# В строке обычно добавляют: ?pgbouncer=true&connection_limit=1&sslmode=require
# (Supabase Dashboard → Connect → ORM / Transaction pooler).
#
# Символы # ( ) * ^ в пароле в URL нужно кодировать (%23 %28 %29 %2A %5E).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vd?schema=public"
# Миграции не входят в `npm run build` (Vercel). После смены схемы: локально или в CI выполните
# `npx prisma migrate deploy`, подставив для Supabase строку на pooler :5432 (session) или Direct URI
# из Dashboard — transaction pooler :6543 для migrate часто не подходит.
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Продакшен: точный URL сайта (важно для cookies и редиректов NextAuth).
# Локально: http://localhost:3000
AUTH_URL="http://localhost:3000"

# Риск «тишина» исполнителя (дни). Предупреждение < высокого риска.
SILENCE_WARNING_DAYS="3"
SILENCE_HIGH_DAYS="7"

# Уведомления (lib/notification-settings.ts, lib/notifications.ts)
# NOTIFY_EMAIL_ENABLED="false"
# NOTIFY_ADMIN_EMAIL=""
# NOTIFY_ADMIN_TOAST="true"
# NOTIFY_EXECUTOR_TOAST="true"
# NOTIFY_PUSH_ENABLED="false"
