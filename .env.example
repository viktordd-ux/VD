# Локально: Docker postgres.
#
# Supabase на Vercel: для runtime приложения используйте Transaction pooler (порт 6543),
# НЕ Session pooler — у session mode жёсткий лимит соединений и ошибка MaxClientsInSessionMode.
# В строке обычно добавляют: ?pgbouncer=true&connection_limit=1&sslmode=require
# (Supabase Dashboard → Connect → ORM / Transaction pooler).
#
# Символы # ( ) * ^ в пароле в URL нужно кодировать (%23 %28 %29 %2A %5E).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vd?schema=public"
#
# Обязательно в Vercel (Settings → Environment Variables), иначе прод не поднимется / Prisma падает:
# - DATABASE_URL — pooler (Transaction, :6543 или URI из «ORM») с pgbouncer=true и т.д.
# - DIRECT_URL — прямое подключение (host db.xxx.supabase.co, порт 5432), из Dashboard «Direct connection».
#   Без DIRECT_URL в схеме prisma/schema.prisma приложение на проде не стартует.
# - AUTH_SECRET — тот же, что локально (openssl rand -base64 32).
# - AUTH_URL — полный URL продакшена: https://ваш-проект.vercel.app или свой домен (для NextAuth cookies).
#
# Миграции не входят в `npm run build` (Vercel). После смены схемы: локально или в CI выполните
# `npx prisma migrate deploy`, подставив для Supabase строку на pooler :5432 (session) или Direct URI
# из Dashboard — transaction pooler :6543 для migrate часто не подходит.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/vd?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Продакшен: точный URL сайта (важно для cookies и редиректов NextAuth).
# Локально: http://localhost:3000
AUTH_URL="http://localhost:3000"

# Время в чате зафиксировано в коде как Europe/Moscow (переменная не используется).

# Риск «тишина» исполнителя (дни). Предупреждение < высокого риска.
SILENCE_WARNING_DAYS="3"
SILENCE_HIGH_DAYS="7"

# Уведомления (lib/notification-settings.ts, lib/notifications.ts)
# NOTIFY_EMAIL_ENABLED="false"
# NOTIFY_ADMIN_EMAIL=""
# NOTIFY_ADMIN_TOAST="true"
# NOTIFY_EXECUTOR_TOAST="true"
# NOTIFY_PUSH_ENABLED="false"

# Telegram Bot (@BotFather) — уведомления исполнителям (lib/telegram.ts)
# TELEGRAM_BOT_TOKEN=""
# Тот же секрет, что для /api/cleanup (Vercel Cron → Authorization: Bearer …)
# CRON_SECRET=""

# Web Push (VAPID): `npx web-push generate-vapid-keys`
# Публичный ключ — в VAPID_PUBLIC_KEY и дублируйте в NEXT_PUBLIC_VAPID_PUBLIC_KEY (для клиента / API).
# VAPID_SUBJECT="mailto:you@example.com"
# VAPID_PUBLIC_KEY=""
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
#
# Отладка push: логи сервера (Vercel / терминал) — каждая отправка и subscribe.
# PUSH_DEBUG="1"
# Отладка в браузере: консоль страницы, регистрация SW и подписка.
# NEXT_PUBLIC_PUSH_DEBUG="1"
