# Локально: Docker postgres. Supabase: Session pooler из Connect → Method: Session pooler.
# Символы # ( ) * ^ в пароле в URL нужно кодировать (%23 %28 %29 %2A %5E).
# Для Vercel добавьте: ?sslmode=require&connection_limit=1
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vd?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Локально: http://localhost:3000. На Vercel: https://your-project.vercel.app
AUTH_URL="http://localhost:3000"

# Риск «тишина» исполнителя (дни). Предупреждение < высокого риска.
SILENCE_WARNING_DAYS="3"
SILENCE_HIGH_DAYS="7"

# Уведомления (lib/notification-settings.ts, lib/notifications.ts)
# NOTIFY_EMAIL_ENABLED="false"
# NOTIFY_ADMIN_EMAIL=""
# NOTIFY_ADMIN_TOAST="true"
# NOTIFY_EXECUTOR_TOAST="true"
# NOTIFY_PUSH_ENABLED="false"
