generator client {
  provider = "prisma-client-js"
}

// Миграции (migrate deploy) не встраивайте в Vercel build: Session pooler Supabase даёт
// MaxClientsInSessionMode / лимит сессий. Запускайте migrate локально или в CI с прямым URL
// к БД (Supabase → Connect → Postgres, host db.*.supabase.co:5432, не pooler).
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Legacy: глобальная роль в приложении (admin / executor). Для доступа в организациях используйте `Membership.role` (`MembershipRole`).
enum UserRole {
  admin
  executor
}

/// Роли участника организации (один пользователь может иметь разные роли в разных организациях).
enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  EXECUTOR
  VIEWER
}

enum UserStatus {
  active
  banned
}

enum LeadStatus {
  NEW
  IN_CHAT
  WON
  LOST
}

enum OrderStatus {
  LEAD
  IN_PROGRESS
  REVIEW
  DONE
}

enum FileUploaderRole {
  admin
  executor
}

enum FileEntryKind {
  file
  link
}

enum CheckpointStatus {
  pending
  awaiting_approval
  done
}

enum MessageRole {
  admin
  executor
}

enum NotificationKind {
  order
  chat
  system
}

model User {
  id           String     @id @default(cuid())
  name         String
  firstName    String     @default("") @map("first_name")
  lastName     String     @default("") @map("last_name")
  email        String     @unique
  passwordHash String     @map("password_hash")
  /// @deprecated Историческое поле; новая модель ролей — `Membership` и `MembershipRole`.
  role         UserRole
  status       UserStatus
  phone        String?    @map("phone")
  telegram     String?    @map("telegram")
  // Числовой chat_id в Telegram (для бота), не путать с @username
  telegramId   String?    @map("telegram_id")
  skills       String[]   @default([])
  primarySkill String     @default("") @map("primary_skill")
  onboarded    Boolean    @default(false) @map("onboarded")
  pushEnabled  Boolean    @default(false) @map("push_enabled")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  ordersAsExecutor Order[]    @relation("OrderExecutor")
  pushSubscriptions PushSubscription[]
  auditLogs        AuditLog[]
  messagesSent     Message[]
  messageReactions MessageReaction[]
  orderReadStates  OrderUserReadState[]
  notifications    Notification[]

  ownedOrganizations Organization[] @relation("OrganizationOwner")
  memberships        Membership[]
  teamMembers        TeamMember[]
  orderExecutorRows  OrderExecutor[]

  @@map("users")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")

  owner   User         @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members Membership[]
  teams   Team[]
  orders  Order[]

  @@map("organizations")
}

model Membership {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  organizationId String         @map("organization_id")
  role           MembershipRole
  createdAt      DateTime       @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("memberships")
}

model Team {
  id             String @id @default(uuid())
  name           String
  organizationId String @map("organization_id")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        TeamMember[]
  orders         Order[]
  orderTemplates OrderTemplate[]

  @@map("teams")
}

model TeamMember {
  id     String @id @default(uuid())
  teamId String @map("team_id")
  userId String @map("user_id")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model OrderTemplate {
  id                  String   @id @default(cuid())
  title               String
  descriptionTemplate String   @map("description_template") @db.Text
  defaultCheckpoints  Json     @default("[]") @map("default_checkpoints")
  tags                String[] @default([])
  teamId              String?  @map("team_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  orders Order[]

  @@index([teamId])
  @@map("order_templates")
}

model Lead {
  id         String     @id @default(cuid())
  link       String
  clientName String     @map("client_name")
  platform   String
  text       String     @db.Text
  notes      String?    @db.Text
  status     LeadStatus
  deletedAt  DateTime?  @map("deleted_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  orders Order[]

  @@index([deletedAt])
  @@map("leads")
}

/// Назначенные исполнители заказа (дополнительно к legacy `Order.executorId`).
model OrderExecutor {
  id      String @id @default(uuid())
  orderId String @map("order_id")
  userId  String @map("user_id")

  order Order @relation("OrderExecutorLinks", fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orderId, userId])
  @@map("order_executors")
}

model Order {
  id              String      @id @default(cuid())
  title           String
  description     String      @db.Text
  clientName      String      @map("client_name")
  platform        String
  deadline        DateTime?
  budgetClient    Decimal     @map("budget_client") @db.Decimal(12, 2)
  budgetExecutor  Decimal     @map("budget_executor") @db.Decimal(12, 2)
  profit          Decimal     @db.Decimal(12, 2)
  status          OrderStatus
  executorId      String?     @map("executor_id")
  leadId          String?     @map("lead_id")
  revisionCount   Int         @default(0) @map("revision_count")
  requiredSkills  String[]    @default([]) @map("required_skills")
  templateId      String?     @map("template_id")
  organizationId  String      @map("organization_id")
  teamId          String?     @map("team_id")
  deletedAt       DateTime?   @map("deleted_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  team         Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  executor    User?           @relation("OrderExecutor", fields: [executorId], references: [id], onDelete: SetNull)
  orderExecutors OrderExecutor[] @relation("OrderExecutorLinks")
  template    OrderTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  lead        Lead?        @relation(fields: [leadId], references: [id])
  files       File[]
  checkpoints Checkpoint[]
  messages         Message[]
  messageReactions MessageReaction[]
  userReadStates   OrderUserReadState[]

  @@index([executorId])
  @@index([status])
  @@index([templateId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([teamId])
  @@index([deletedAt])
  @@map("orders")
}

model File {
  id          String           @id @default(cuid())
  orderId     String           @map("order_id")
  uploadedBy  FileUploaderRole @map("uploaded_by")
  kind        FileEntryKind    @default(file)
  filePath    String?          @map("file_path")
  externalUrl String?          @map("external_url") @db.Text
  linkTitle   String?          @map("link_title") @db.Text
  comment     String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("files")
}

model Checkpoint {
  id        String           @id @default(cuid())
  orderId   String           @map("order_id")
  title     String
  status    CheckpointStatus
  dueDate   DateTime?        @map("due_date")
  paymentAmount    Decimal    @default(0) @map("payment_amount") @db.Decimal(12, 2)
  payoutReleasedAt DateTime?  @map("payout_released_at")
  position  Int              @default(0)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, position])
  @@map("checkpoints")
}

model Message {
  id          String      @id @default(uuid()) @db.Uuid
  orderId     String      @map("order_id")
  senderId    String      @map("sender_id")
  role        MessageRole
  text        String      @db.Text
  attachments Json        @default("[]")
  createdAt   DateTime    @default(now()) @map("created_at")
  replyToId   String?     @map("reply_to_id") @db.Uuid

  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender    User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo   Message?          @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[]         @relation("MessageReply")
  reactions MessageReaction[]

  @@index([orderId])
  @@index([orderId, createdAt])
  @@index([replyToId])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  orderId   String   @map("order_id")
  userId    String   @map("user_id")
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([orderId])
  @@map("message_reactions")
}

/// Водяные знаки «прочитано»: чат и страница заказа (файлы, этапы, поля) раздельно.
model OrderUserReadState {
  userId        String    @map("user_id")
  orderId       String    @map("order_id")
  chatReadAt    DateTime? @map("chat_read_at")
  projectReadAt DateTime? @map("project_read_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@id([userId, orderId])
  @@map("order_user_read_state")
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  actionType  String   @map("action_type")
  changedById String   @map("changed_by")
  changedAt   DateTime @default(now()) @map("changed_at")
  diff        Json?

  changedBy User @relation(fields: [changedById], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([changedAt])
  @@map("audit_log")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

/// Внутри приложения: чат, заказы, системные события (для админов и исполнителей).
model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  kind      NotificationKind
  title     String
  body      String           @db.Text
  linkHref  String?          @map("link_href") @db.Text
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}
