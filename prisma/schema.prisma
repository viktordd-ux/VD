generator client {
  provider = "prisma-client-js"
}

// Миграции (migrate deploy) не встраивайте в Vercel build: Session pooler Supabase даёт
// MaxClientsInSessionMode / лимит сессий. Запускайте migrate локально или в CI с прямым URL
// к БД (Supabase → Connect → Postgres, host db.*.supabase.co:5432, не pooler).
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  executor
}

enum UserStatus {
  active
  banned
}

enum LeadStatus {
  NEW
  IN_CHAT
  WON
  LOST
}

enum OrderStatus {
  LEAD
  IN_PROGRESS
  REVIEW
  DONE
}

enum FileUploaderRole {
  admin
  executor
}

enum FileEntryKind {
  file
  link
}

enum CheckpointStatus {
  pending
  awaiting_approval
  done
}

enum MessageRole {
  admin
  executor
}

model User {
  id           String     @id @default(cuid())
  name         String
  firstName    String     @default("") @map("first_name")
  lastName     String     @default("") @map("last_name")
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole
  status       UserStatus
  phone        String?    @map("phone")
  telegram     String?    @map("telegram")
  // Числовой chat_id в Telegram (для бота), не путать с @username
  telegramId   String?    @map("telegram_id")
  skills       String[]   @default([])
  primarySkill String     @default("") @map("primary_skill")
  onboarded    Boolean    @default(false) @map("onboarded")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  ordersAsExecutor Order[]    @relation("OrderExecutor")
  auditLogs        AuditLog[]
  messagesSent     Message[]

  @@map("users")
}

model OrderTemplate {
  id                  String   @id @default(cuid())
  title               String
  descriptionTemplate String   @map("description_template") @db.Text
  defaultCheckpoints  Json     @default("[]") @map("default_checkpoints")
  tags                String[] @default([])
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("order_templates")
}

model Lead {
  id         String     @id @default(cuid())
  link       String
  clientName String     @map("client_name")
  platform   String
  text       String     @db.Text
  notes      String?    @db.Text
  status     LeadStatus
  deletedAt  DateTime?  @map("deleted_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  orders Order[]

  @@index([deletedAt])
  @@map("leads")
}

model Order {
  id              String      @id @default(cuid())
  title           String
  description     String      @db.Text
  clientName      String      @map("client_name")
  platform        String
  deadline        DateTime?
  budgetClient    Decimal     @map("budget_client") @db.Decimal(12, 2)
  budgetExecutor  Decimal     @map("budget_executor") @db.Decimal(12, 2)
  profit          Decimal     @db.Decimal(12, 2)
  status          OrderStatus
  executorId      String?     @map("executor_id")
  leadId          String?     @map("lead_id")
  revisionCount   Int         @default(0) @map("revision_count")
  requiredSkills  String[]    @default([]) @map("required_skills")
  templateId      String?     @map("template_id")
  deletedAt       DateTime?   @map("deleted_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  executor    User?           @relation("OrderExecutor", fields: [executorId], references: [id], onDelete: SetNull)
  template    OrderTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  lead        Lead?        @relation(fields: [leadId], references: [id])
  files       File[]
  checkpoints Checkpoint[]
  messages    Message[]

  @@index([executorId])
  @@index([status])
  @@index([templateId])
  @@index([deletedAt])
  @@map("orders")
}

model File {
  id          String           @id @default(cuid())
  orderId     String           @map("order_id")
  uploadedBy  FileUploaderRole @map("uploaded_by")
  kind        FileEntryKind    @default(file)
  filePath    String?          @map("file_path")
  externalUrl String?          @map("external_url") @db.Text
  linkTitle   String?          @map("link_title") @db.Text
  comment     String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("files")
}

model Checkpoint {
  id        String           @id @default(cuid())
  orderId   String           @map("order_id")
  title     String
  status    CheckpointStatus
  dueDate   DateTime?        @map("due_date")
  paymentAmount    Decimal    @default(0) @map("payment_amount") @db.Decimal(12, 2)
  payoutReleasedAt DateTime?  @map("payout_released_at")
  position  Int              @default(0)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, position])
  @@map("checkpoints")
}

model Message {
  id        String      @id @default(uuid()) @db.Uuid
  orderId   String      @map("order_id")
  senderId  String      @map("sender_id")
  role      MessageRole
  text      String      @db.Text
  createdAt DateTime    @default(now()) @map("created_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, createdAt])
  @@map("messages")
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  actionType  String   @map("action_type")
  changedById String   @map("changed_by")
  changedAt   DateTime @default(now()) @map("changed_at")
  diff        Json?

  changedBy User @relation(fields: [changedById], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([changedAt])
  @@map("audit_log")
}
